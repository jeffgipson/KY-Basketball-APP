# =============================================================================
# KHSBHOF Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudflare Worker secrets (set via `wrangler secret put` or Workers dashboard)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Allowed CORS origin for the Worker (set to your WordPress site domain)
ALLOWED_ORIGIN=https://acclaimpress.com

# -----------------------------------------------------------------------------
# Frontend (public — baked at build time via Vite)
# These are safe to expose in the browser bundle.
# -----------------------------------------------------------------------------
VITE_WORKER_URL=https://khsbhof-chat.workers.dev
VITE_ANALYTICS_TOKEN=

# Enable/disable search engine indexing ('true' = index, 'false' = noindex)
VITE_ENABLE_INDEXING=false

# -----------------------------------------------------------------------------
# Ingestion pipeline (used locally by ingestion/*.py scripts)
# -----------------------------------------------------------------------------
INGESTION_SUPABASE_URL=https://your-project.supabase.co
INGESTION_SUPABASE_SERVICE_KEY=eyJ...
INGESTION_VOYAGE_API_KEY=pa-...
